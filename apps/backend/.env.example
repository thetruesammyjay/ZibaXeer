# ──────────────────────────────────────────────
# ZibaXeer Backend — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# ─── Database ────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DATABASE_URL=postgresql://user:password@localhost:5432/zibaxeer?schema=public

# ─── Redis ───────────────────────────────────
# Must be the same Redis instance used by apps/indexer
REDIS_URL=redis://127.0.0.1:6379

# ─── Server ──────────────────────────────────
# Port the Express API server listens on
PORT=4000

# ─── CORS ────────────────────────────────────
# URL of the frontend (allows cross-origin requests from your UI)
# Use * to allow all origins in development
FRONTEND_URL=http://localhost:3000

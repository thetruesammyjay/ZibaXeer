# ──────────────────────────────────────────────
# ZibaXeer Indexer — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# HyperPaxeer RPC endpoint (EVM Chain ID: 125)
HYPERPAXEER_RPC_URL=https://mainnet-beta.rpc.hyperpaxeer.com/rpc

# Deployed VaultFactory proxy address
VAULT_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# Comma-separated list of vault addresses deployed before this indexer started
# Leave empty if there are no pre-existing vaults to bootstrap
KNOWN_VAULT_ADDRESSES=

# Redis connection string (must be the same instance used by apps/backend)
REDIS_URL=redis://127.0.0.1:6379

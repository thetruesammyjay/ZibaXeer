# ──────────────────────────────────────────────
# ZibaXeer Contracts — Deployment Environment
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# ─── Deployer Wallet ─────────────────────────
# Private key of the wallet that will deploy ALL contracts
DEPLOYER_PRIVATE_KEY=0x...

# Public address of the deployer wallet (must match the private key above)
DEPLOYER_ADDRESS=0x...

# ─── External Dependencies ───────────────────
# PaxDex Router address on HyperPaxeer mainnet (required by PaxDexAdapter)
PAX_DEX_ROUTER_ADDRESS=0x...

# ─── PaxScan Verification ────────────────────
# Register at https://paxscan.paxeer.app to get your API key
PAXSCAN_API_KEY=your_api_key_here

# ─── Network ─────────────────────────────────
# HyperPaxeer RPC (default already set in foundry.toml, override here if needed)
# HYPERPAXEER_RPC_URL=https://mainnet-beta.rpc.hyperpaxeer.com/rpc
